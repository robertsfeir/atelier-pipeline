{
  "name": "atelier-pipeline",
  "version": "3.29.0",
  "description": "Multi-agent orchestration for AI-powered IDEs — quality gates, wave-based QA, and persistent institutional memory",
  "license": "Apache-2.0",
  "author": {
    "name": "Robert Sfeir",
    "email": "robert@sfeir.design"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -d \"${CURSOR_PLUGIN_ROOT}/brain/node_modules\" || npm install --prefix \"${CURSOR_PLUGIN_ROOT}/brain\" --silent"
          },
          {
            "type": "command",
            "command": "bash \"${CURSOR_PLUGIN_ROOT}/scripts/check-updates.sh\" \"${CURSOR_PLUGIN_ROOT}\""
          },
          {
            "type": "command",
            "command": "node \"${CURSOR_PLUGIN_ROOT}/brain/scripts/hydrate-telemetry.mjs\" \"${CURSOR_PROJECT_DIR}\" --silent --state-dir \"${CURSOR_PROJECT_DIR}/docs/pipeline\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
