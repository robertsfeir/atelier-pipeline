{
  "pipeline_state_dir": "docs/pipeline",
  "colby_blocked_paths": [
    "docs/",
    ".gitlab-ci",
    ".circleci/",
    "Jenkinsfile",
    "Dockerfile",
    "docker-compose",
    ".gitlab/",
    "deploy/",
    "infra/",
    "terraform/",
    "pulumi/",
    "k8s/",
    "kubernetes/"
  ],
  "test_command": "pytest tests/hooks/ && cd brain && node --test ../tests/brain/*.test.mjs",
  "test_patterns": [
    ".test.",
    ".spec.",
    "/tests/",
    "/__tests__/",
    "/test_",
    "_test.",
    "conftest"
  ]
}
