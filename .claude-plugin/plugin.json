{
  "name": "atelier-pipeline",
  "version": "1.0.0",
  "description": "Multi-agent orchestration with quality gates, continuous QA, and persistent institutional memory across sessions",
  "author": { "name": "Robert Sfeir" },
  "keywords": ["pipeline", "agents", "orchestration", "quality", "tdd", "qa"],
  "skills": [
    "./skills/pipeline-overview",
    "./skills/pipeline-setup",
    "./skills/brain-setup",
    "./skills/brain-hydrate"
  ],
  "mcpServers": {
    "atelier-brain": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/brain/server.mjs"],
      "env": {
        "DATABASE_URL": "${ATELIER_BRAIN_DATABASE_URL}",
        "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}",
        "BRAIN_CONFIG_PROJECT": "${CLAUDE_PROJECT_DIR}/.claude/brain-config.json",
        "BRAIN_CONFIG_USER": "${CLAUDE_PLUGIN_DATA}/brain-config.json"
      }
    }
  }
}
